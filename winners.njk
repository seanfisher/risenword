---
title: Prize Winners
description: All winners and runners-up from every Risen Word Easter Poetry Contest.
layout: layout.njk
permalink: /winners/
---

<div class="max-w-3xl mx-auto">
  <h1 class="font-playfair text-4xl font-bold text-center text-text mb-2">Prize Winners</h1>
  <p class="text-center text-gray-500 mb-10">Award-winning poetry from every Risen Word Easter Contest.</p>

  {% for year in collections.contestYears | reverse %}
    {% set contest = collections.contestsByYear[year] %}
    {% set yearPoems = collections.poemsByYear[year] | default([]) %}

    {% set winners = [] %}
    {% set runnersUp = [] %}
    {% for poem in yearPoems %}
      {% if poem.data.award == "winner" %}
        {% set winners = winners.concat([poem]) %}
      {% elif poem.data.award == "runner-up" %}
        {% set runnersUp = runnersUp.concat([poem]) %}
      {% endif %}
    {% endfor %}

    {% if winners.length > 0 or runnersUp.length > 0 %}
      <section class="mb-14" aria-labelledby="year-{{ year }}-heading">

        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-6 pb-3 border-b border-[#e8e4dd]">
          <h2 id="year-{{ year }}-heading" class="font-playfair text-2xl font-bold text-text">{{ year }}</h2>
          {% if contest and contest.theme %}
            <span class="text-gray-400 italic text-sm">&#8220;{{ contest.theme }}&#8221;</span>
          {% endif %}
          <a href="/contests/{{ year }}/" class="ml-auto text-accent text-sm hover:underline font-medium whitespace-nowrap">Full results &#8594;</a>
        </div>

        {% if winners.length > 0 %}
          <p class="text-xs font-semibold uppercase tracking-widest text-yellow-600 mb-3">&#127942; Winners</p>
          <div class="grid sm:grid-cols-2 gap-4 mb-8">
            {% for poem in winners %}
              <a
                href="{{ poem.url }}"
                class="block p-5 rounded-xl bg-gradient-to-br from-yellow-50 to-amber-100 border border-yellow-200 hover:shadow-lg hover:border-yellow-300 transition-all group"
                aria-label="Read {{ poem.data.title }} by {{ poem.data.author }}"
              >
                <p class="text-xs uppercase tracking-widest text-yellow-700 font-semibold mb-2">{{ poem.data.category }}</p>
                <h3 class="font-playfair text-xl font-bold text-text leading-snug mb-1 group-hover:text-accent transition-colors">&#8220;{{ poem.data.title }}&#8221;</h3>
                <p class="text-sm text-gray-600 mb-3">by {{ poem.data.author }}</p>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{{ poem.content | striptags | truncate(120) }}</p>
                <p class="mt-3 text-accent text-sm font-medium group-hover:underline">Read poem &#8594;</p>
              </a>
            {% endfor %}
          </div>
        {% endif %}

        {% if runnersUp.length > 0 %}
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-3">&#129352; Runners-Up</p>
          <div class="grid sm:grid-cols-2 gap-4">
            {% for poem in runnersUp %}
              <a
                href="{{ poem.url }}"
                class="block p-5 rounded-xl bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200 hover:shadow-lg hover:border-slate-300 transition-all group"
                aria-label="Read {{ poem.data.title }} by {{ poem.data.author }}"
              >
                <p class="text-xs uppercase tracking-widest text-gray-500 font-semibold mb-2">{{ poem.data.category }}</p>
                <h3 class="font-playfair text-xl font-bold text-text leading-snug mb-1 group-hover:text-accent transition-colors">&#8220;{{ poem.data.title }}&#8221;</h3>
                <p class="text-sm text-gray-600 mb-3">by {{ poem.data.author }}</p>
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{{ poem.content | striptags | truncate(120) }}</p>
                <p class="mt-3 text-accent text-sm font-medium group-hover:underline">Read poem &#8594;</p>
              </a>
            {% endfor %}
          </div>
        {% endif %}

      </section>
    {% endif %}
  {% endfor %}
</div>
