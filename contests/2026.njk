---
title: 2026 Contest
layout: home.njk
description: Details and submission links for the 2026 Risen Word Easter Poetry Contest.
---
<section class="max-w-5xl mx-auto mb-12" aria-label="2026 contest details">
  <header class="relative overflow-hidden rounded-2xl border border-[#e8e4dd] bg-[radial-gradient(1200px_500px_at_50%_-100px,rgba(255,90,71,0.18),transparent_60%),radial-gradient(900px_420px_at_0%_30%,rgba(255,90,71,0.10),transparent_55%)] px-6 pt-10 pb-8 sm:px-10 sm:pt-12 sm:pb-10">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3">
        <span class="inline-flex items-center gap-3 rounded-full border border-[#eadfd6] bg-white/70 px-4 py-1 text-sm font-semibold uppercase tracking-[0.18em] text-accent shadow-sm">
          <span>2nd Annual</span>
          <span class="h-4 w-px bg-[#eadfd6]" aria-hidden="true"></span>
          <span class="text-text">2026</span>
        </span>
      </p>
      <h1 class="font-playfair text-5xl sm:text-6xl font-bold tracking-tight text-text">
        Easter Poetry Contest
      </h1>

      <p class="mt-4 text-lg text-gray-700 leading-relaxed">
        Winners are selected based on artistic merit, spiritual depth, and the ability to communicate the Easter message in fresh and compelling ways.
      </p>

      <div class="mt-8 mb-8">
        <p class="text-xs uppercase tracking-[0.14em] text-gray-600 mb-2">Theme</p>
        <p class="text-accent font-semibold text-2xl">
          <span class="sr-only">Theme:</span>
          <em>"As He Said"</em>
        </p>
      </div>

      <div class="flex justify-center" aria-label="Submission link">
        <a
          href="/submit"
          data-submit-link
          class="inline-flex items-center justify-center bg-accent text-white font-bold py-3 px-8 rounded-lg hover:bg-accentHover transition focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
        >Submit Your Poem</a>
      </div>

      <p
        class="mt-10 text-accent font-semibold text-base tracking-wide"
        id="countdown"
        role="status"
        aria-live="polite"
      >Submit by end of day on Good Friday.</p>
    </div>
  </header>

  <div class="mt-8 rounded-2xl border border-[#e8e4dd] bg-white p-6 sm:p-8 shadow-sm">
    <div class="grid gap-8 md:grid-cols-2 md:gap-10">
      <section aria-labelledby="at-a-glance">
        <h2 id="at-a-glance" class="font-playfair text-2xl font-semibold text-text mb-4">
          At a glance
        </h2>

        <dl class="space-y-4 text-gray-700">
          <div class="pt-4 border-t border-[#e8e4dd]">
            <dt class="text-sm tracking-wide text-gray-500">Deadline</dt>
            <dd class="mt-1">
              End of day <strong>Good Friday</strong>
            </dd>
          </div>
          <div class="pt-4 border-t border-[#e8e4dd]">
            <dt class="text-sm tracking-wide text-gray-500">Categories</dt>
            <dd class="mt-1 space-y-2">
              <div><strong>Short Form</strong> (under 12 lines, including haiku, tanka, and other brief forms)</div>
              <div><strong>Long Form</strong> (12+ lines, including sonnets, free verse, and narrative poems)</div>
            </dd>
          </div>
          <div class="pt-4 border-t border-[#e8e4dd]">
            <dt class="text-sm tracking-wide text-gray-500">Prizes</dt>
            <dd class="mt-1">$30 Best in Category · $20 Runner-Up</dd>
          </div>
          <div class="pt-4 border-t border-[#e8e4dd]">
            <dt class="text-sm tracking-wide text-gray-500">Who can enter</dt>
            <dd class="mt-1">All ages welcome.</dd>
          </div>
        </dl>
      </section>

      <section aria-labelledby="how-to-submit" class="md:border-l md:border-[#e8e4dd] md:pl-8">
        <h2 id="how-to-submit" class="font-playfair text-2xl font-semibold text-text mb-4">
          How to submit
        </h2>

        <ol class="space-y-3 text-gray-700">
          <li class="flex gap-3">
            <span class="text-accent font-bold" aria-hidden="true">1</span>
            <span>Write your poem (short or long form).</span>
          </li>
          <li class="flex gap-3">
            <span class="text-accent font-bold" aria-hidden="true">2</span>
            <span><a href="/submit" class="text-accent hover:text-accentHover underline font-semibold">Submit here</a> using our online form.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-accent font-bold" aria-hidden="true">3</span>
            <span>Include your name, poem title, and any AI disclosure if applicable.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-accent font-bold" aria-hidden="true">4</span>
            <span>A voting link will be sent out to all participants after submissions close.</span>
          </li>
        </ol>

        <div class="mt-6 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5">
          <p class="text-sm text-gray-700 leading-relaxed">
            "As He Said" invites poetry that reflects on the words He spoke and their perfect fulfillment through his being and actions.
          </p>
        </div>
      </section>
    </div>
  </div>

  <section class="mt-10" aria-labelledby="guidelines">
    <div class="rounded-2xl border border-[#e8e4dd] bg-white p-6 sm:p-8 shadow-sm">
      <h2 id="guidelines" class="font-playfair text-2xl font-semibold text-text">Guidelines</h2>

      <ul class="mt-5 grid gap-4 text-gray-700 sm:grid-cols-2">
        <li class="flex gap-3 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5">
          <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-accent/15 text-accent font-bold" aria-hidden="true">✓</span>
          <span>All entries may be featured on <strong>risenword.org</strong>.</span>
        </li>
        <li class="flex gap-3 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5">
          <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-accent/15 text-accent font-bold" aria-hidden="true">✓</span>
          <span>Non-original work is welcome, but <strong>not eligible for prizes</strong>.</span>
        </li>
        <li class="flex gap-3 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5">
          <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-accent/15 text-accent font-bold" aria-hidden="true">✓</span>
          <span><strong>AI use is allowed</strong>, but it must be disclosed.</span>
        </li>
        <li class="flex gap-3 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5">
          <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-accent/15 text-accent font-bold" aria-hidden="true">✓</span>
          <span>You may submit <strong>multiple quality entries</strong>.</span>
        </li>
        <li class="flex gap-3 rounded-xl bg-[#fff7f2] p-4 ring-1 ring-black/5 sm:col-span-2">
          <span class="mt-0.5 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-accent/15 text-accent font-bold" aria-hidden="true">✓</span>
          <span><strong>Voting is anonymous and democratic.</strong> Each participant receives two votes, which cannot be used for their own work.</span>
        </li>
      </ul>
    </div>
  </section>
</section>

<script>
  const countdown = document.getElementById('countdown');
  const submitLinks = Array.from(document.querySelectorAll('[data-submit-link]'));
  const deadline = new Date(2026, 3, 3, 23, 59, 59).getTime(); // Good Friday, end of day (local time)

  function setTime() {
    const now = new Date().getTime();
    const distance = deadline - now;

    if (distance <= 0) {
      clearInterval(intervalId);
      countdown.textContent = "Submissions are now closed.";
      submitLinks.forEach((link) => {
        link.classList.add('hidden');
        link.setAttribute('aria-disabled', 'true');
        link.setAttribute('tabindex', '-1');
      });
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const deadlineDate = new Date(deadline);
    const deadlineLabel = deadlineDate.toLocaleString(undefined, {
      weekday: 'long',
      month: 'short',
      day: 'numeric',
      year: 'numeric'
    });

    countdown.textContent = `Deadline: ${deadlineLabel} · ${days}d ${hours}h ${minutes}m remaining`;
  }

  const intervalId = setInterval(setTime, 1000);
  setTime();
</script>
