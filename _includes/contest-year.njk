{% extends "base.njk" %}

{% block content %}

{% import "./_macros/poem-preview.njk" as poemPreview %}
{% set poems = collections.poemsByYear[year] | default([]) %}
<div class="max-w-3xl mx-auto px-4">

  <h1 class="text-4xl font-serif font-bold text-center my-8">{{ title }}</h1>
  {% if theme %}
    <p class="text-center text-gray-500 text-sm uppercase tracking-widest mb-10">Theme: <span class="font-semibold text-text">{{ theme }}</span></p>
  {% endif %}

  {# Build dynamic unique list of categories #}
  {% set categories = [] %}
  {% for poem in poems %}
    {% if categories.indexOf(poem.data.category) == -1 %}
      {% set categories = categories.concat([poem.data.category]) %}
    {% endif %}
  {% endfor %}

  {% for cat in categories %}
    <section class="mb-12">
      <h2 class="text-2xl font-serif font-bold text-[#2c2c2c] mb-5 pb-2 border-b border-gray-200">{{ cat | capitalize }} Poems</h2>

      {# Filter poems by this category #}
      {% set filteredPoems = [] %}
      {% for poem in poems %}
        {% if poem.data.category == cat %}
          {% set filteredPoems = filteredPoems.concat([poem]) %}
        {% endif %}
      {% endfor %}

      {% set winner = null %}
      {% set runnersUp = [] %}
      {% for poem in filteredPoems %}
        {% if poem.data.award == "winner" %}
          {% set winner = poem %}
        {% elseif poem.data.award == "runner-up" %}
          {% set runnersUp = runnersUp.concat([poem]) %}
        {% endif %}
      {% endfor %}

      {% if winner %}
        <div class="relative w-full bg-gradient-to-br from-yellow-300 to-yellow-200 text-gray-800 p-5 rounded-xl shadow mb-4 hover:shadow-md transition">
          <a href="{{ winner.url }}" class="absolute inset-0 rounded-xl" aria-label="Read {{ winner.data.title }}"></a>
          <p class="text-xs uppercase tracking-widest font-bold text-yellow-800 mb-2">🏆 Winner</p>
          <h3 class="text-xl font-serif font-bold leading-snug">{{ winner.data.title }}</h3>
          <p class="text-gray-700 text-sm mb-2">by {{ winner.data.author }}</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-3">{{ winner.content | striptags | truncate(150) }}</p>
          <a href="{{ winner.url }}" class="relative text-blue-700 hover:underline text-sm font-medium">Read Full Poem →</a>
        </div>
      {% endif %}

      {% for runnerUp in runnersUp %}
        <div class="relative w-full bg-gradient-to-br from-gray-100 to-gray-50 border border-gray-200 text-gray-800 p-5 rounded-xl shadow-sm mb-4 hover:shadow transition">
          <a href="{{ runnerUp.url }}" class="absolute inset-0 rounded-xl" aria-label="Read {{ runnerUp.data.title }}"></a>
          <p class="text-xs uppercase tracking-widest font-bold text-gray-500 mb-2">🥈 Runner-Up</p>
          <h3 class="text-xl font-serif font-bold leading-snug">{{ runnerUp.data.title }}</h3>
          <p class="text-gray-600 text-sm mb-2">by {{ runnerUp.data.author }}</p>
          <p class="text-gray-500 text-sm leading-relaxed mb-3">{{ runnerUp.content | striptags | truncate(150) }}</p>
          <a href="{{ runnerUp.url }}" class="relative text-blue-600 hover:underline text-sm font-medium">Read Full Poem →</a>
        </div>
      {% endfor %}

      {% set otherPoems = [] %}
      {% for poem in filteredPoems %}
        {% if poem != winner and runnersUp.indexOf(poem) == -1 %}
          {% set otherPoems = otherPoems.concat([poem]) %}
        {% endif %}
      {% endfor %}

      {% if otherPoems.length > 0 %}
        <h3 class="text-sm uppercase tracking-widest text-gray-400 font-semibold mt-6 mb-3">All Other Entries</h3>
        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {% for poem in otherPoems %}
            <li class="bg-white border border-gray-100 p-4 rounded-xl shadow-sm hover:shadow transition">
              <a href="{{ poem.url }}" class="block">
                <h4 class="text-base font-serif font-bold text-text leading-snug mb-1">{{ poem.data.title }}</h4>
                <p class="text-gray-500 text-sm mb-2">by {{ poem.data.author }}</p>
                <p class="text-gray-400 text-xs leading-relaxed">{{ poem.content | striptags | truncate(120) }}</p>
              </a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </section>
  {% endfor %}

  {{ content | safe }}

  {% set prevYear = year - 1 %}
  {% set nextYear = year + 1 %}
  {% set hasPrev = collections.poemsByYear[prevYear] %}
  {% set hasNext = collections.poemsByYear[nextYear] %}
  {% if hasPrev or hasNext %}
    <nav class="flex justify-between items-center mt-10 pt-6 border-t border-gray-200 text-sm" aria-label="Contest year navigation">
      <div>
        {% if hasPrev %}
          <a href="/contests/{{ prevYear }}/" class="text-accent hover:text-accentHover font-medium">← {{ prevYear }} Contest</a>
        {% endif %}
      </div>
      <div>
        {% if hasNext %}
          <a href="/contests/{{ nextYear }}/" class="text-accent hover:text-accentHover font-medium">{{ nextYear }} Contest →</a>
        {% endif %}
      </div>
    </nav>
  {% endif %}
</div>

{% endblock %}