<!DOCTYPE html>
<html lang="en" class="bg-background text-text font-crimson">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title and title != "Home" %}{{ title }}{% if author %} by {{ author }}{% endif %} | {{ site.title }}{% else %}{{ site.title }} — {{ site.tagline }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <meta name="generator" content="{{ eleventy.generator }}">
    {% if page.url == '/' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ site.title | dump }},
      "url": "{{ site.url }}",
      "description": {{ site.description | dump }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ site.url }}/poems/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    {% endif %}

    <link href="/assets/styles/index.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="/fonts/tan-mon-cheri.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/BDScript-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
  </head>
<body class="flex flex-col items-center">
  <div role="banner" class="w-full bg-amber-100 border-b border-amber-300 text-amber-900 text-sm text-center py-2 px-4">
    If you are <strong>Michael Miller</strong>, please contact us at <a href="mailto:lookingformichaelmiller@risenword.org" class="underline font-semibold hover:text-amber-700">lookingformichaelmiller@risenword.org</a>
  </div>
  <header class="w-full {% if page.url != '/' %}mt-5{% else %}mt-10{% endif %} text-center flex flex-col items-center">
    {% if page.url == '/' %}
      <div class="font-tan-mon-cheri text-4xl tracking-wide mb-2">
        <span class="font-beautifully-delicious text-7xl mb-2 block">The</span> RISEN WORD
      </div>
    {% endif %}
    <div class="w-full max-w-5xl flex justify-center items-center py-2">
      {% include "_partials/nav.njk" %}
    </div>
  </header>

  <main class="w-full p-4 bg-white my-1 shadow-none rounded-none sm:w-11/12 sm:max-w-3xl sm:p-8 sm:shadow-lg sm:rounded-lg">
    {% block content -%}{% endblock -%}
  </main>

  <footer class="w-full mt-16 border-t border-[#e8e4dd] bg-[#faf8f5]">
    <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-10 py-12">

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">

        {# Brand column #}
        <div class="col-span-2 sm:col-span-1">
          <div class="font-tan-mon-cheri tracking-wide text-text mb-3">
            <span class="font-beautifully-delicious text-3xl leading-none block">The</span>
            RISEN WORD
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">
            Original poetry celebrating the life, mission, and resurrection of Jesus Christ.
          </p>
        </div>

        {# Poems column #}
        <nav aria-label="Browse poems">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Browse</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/poems" class="text-gray-600 hover:text-accent transition">All Poems</a></li>
            <li><a href="/years/" class="text-gray-600 hover:text-accent transition">By Year</a></li>
            <li><a href="/categories/" class="text-gray-600 hover:text-accent transition">By Category</a></li>
            <li><a href="/authors/" class="text-gray-600 hover:text-accent transition">By Author</a></li>
            <li><a href="/winners/" class="text-gray-600 hover:text-accent transition font-semibold">&#127942; Winners</a></li>
          </ul>
        </nav>

        {# Contest years column #}
        <nav aria-label="Contest results">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Contest Results</h3>
          <ul class="space-y-2 text-sm">
            {% for year in collections.contestYears | reverse %}
              <li><a href="/contests/{{ year }}" class="text-gray-600 hover:text-accent transition">{{ year }} &#8212; <span class="italic">{% if year == 2026 %}As He Said{% elif year == 2025 %}Into the Light{% endif %}</span></a></li>
            {% endfor %}
          </ul>
        </nav>

        {# Site column #}
        <nav aria-label="Site links">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Site</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="text-gray-600 hover:text-accent transition">Home</a></li>
            <li><a href="/about/" class="text-gray-600 hover:text-accent transition">About</a></li>
            <li><a href="/submit/" class="text-gray-600 hover:text-accent transition">Submit a Poem</a></li>
          </ul>
        </nav>

      </div>

      <div class="mt-10 pt-6 border-t border-[#e8e4dd] flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-400">
        <p>&copy; <script>document.write(new Date().getFullYear());</script> Seafish Productions. All rights reserved.</p>
        <p class="italic text-accent">"He is Risen, as He said." — Matthew 28:6</p>
      </div>

    </div>
  </footer>
</body>
</html>
