---
pagination:
  data: collections.poemsByAuthor      # the object you build in .eleventy.js
  size: 1                              # one author per page
  alias: author                        # current item is now “author”
permalink: "/authors/{{ author | slugify }}/"
layout: layout.njk
---

{% from "_macros/poems.njk" import poemListItem %}
{% set poems = collections.poemsByAuthor[author] %}

{% set winners = [] %}
{% set runnersUp = [] %}
{% for poem in poems %}
  {% if poem.data.award == "winner" %}
    {% set winners = winners.concat([poem]) %}
  {% elif poem.data.award == "runner-up" %}
    {% set runnersUp = runnersUp.concat([poem]) %}
  {% endif %}
{% endfor %}

<div class="max-w-3xl mx-auto">
  <nav class="text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href="/authors/" class="hover:text-accent transition-colors">Poets</a></li>
      <li aria-hidden="true" class="text-gray-300">/</li>
      <li class="text-text font-medium">{{ author }}</li>
    </ol>
  </nav>

  <div class="flex items-center gap-4 mb-6">
    <span
      class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-[#fff7f2] text-accent text-2xl font-bold flex-shrink-0"
      aria-hidden="true"
    >{{ author | truncate(1, true, "") }}</span>
    <div>
      <h1 class="font-playfair text-3xl font-bold text-text">{{ author }}</h1>
      <p class="text-gray-400 text-sm mt-0.5">{{ poems | length }} poem{% if poems | length != 1 %}s{% endif %}</p>
    </div>
  </div>

  {% if winners.length > 0 or runnersUp.length > 0 %}
    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {% for poem in winners %}
        <a href="{{ poem.url }}" class="block p-5 rounded-xl bg-gradient-to-br from-yellow-50 to-amber-100 border border-yellow-200 hover:shadow-md transition group">
          <p class="text-xs uppercase tracking-widest text-yellow-700 font-semibold mb-2">🏆 {{ poem.data.year }} {{ poem.data.category }} Winner</p>
          <h3 class="font-playfair text-xl font-bold text-text leading-snug mb-1 group-hover:text-accent transition-colors">&#8220;{{ poem.data.title }}&#8221;</h3>
        </a>
      {% endfor %}
      {% for poem in runnersUp %}
        <a href="{{ poem.url }}" class="block p-5 rounded-xl bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200 hover:shadow-md transition group">
          <p class="text-xs uppercase tracking-widest text-gray-500 font-semibold mb-2">🥈 {{ poem.data.year }} {{ poem.data.category }} Runner-Up</p>
          <h3 class="font-playfair text-xl font-bold text-text leading-snug mb-1 group-hover:text-accent transition-colors">&#8220;{{ poem.data.title }}&#8221;</h3>
        </a>
      {% endfor %}
    </div>

    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">All Poems</h2>
  {% endif %}

  <ul class="space-y-2">
    {% for poem in poems %}
      {{ poemListItem(poem) }}
    {% endfor %}
  </ul>
</div>